// Live voting app - PostgreSQL (Neon in production; connection in prisma.config.ts + adapter in lib/db)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Event {
  id                            String                 @id @default(cuid())
  name                          String
  slug                          String                 @unique
  maxVotesPerUser               Int                    @default(1) // per matchup (or per round if we add round-level later)
  participantsPerMatchup        Int                    @default(2) // how many per matchup in initial/later rounds
  advancesPerMatchup            Int                    @default(1) // how many winners advance from each matchup
  acceptsProducerRegistration   Boolean                @default(false)
  description                   String?
  imageUrl                     String?                @map("image_url")
  venueName                     String?                @map("venue_name")
  address                       String?
  city                          String?
  state                         String?
  zip                           String?
  eventStartsAt                 DateTime?              @map("event_starts_at")
  eventEndsAt                   DateTime?              @map("event_ends_at")
  createdAt                     DateTime               @default(now())
  updatedAt                     DateTime               @updatedAt
  participants                  Participant[]
  rounds                        Round[]
  matchups                      Matchup[]
  showState                     ShowState?
  producerEventSignups          ProducerEventSignup[]
}

model Producer {
  id               String                 @id @default(cuid())
  email            String                 @unique
  passwordHash     String                 @map("password_hash")
  stageName        String                 @map("stage_name")
  slug             String                 @unique
  fullName         String                 @map("full_name")
  phone            String
  instagramHandle  String?                @map("instagram_handle")
  cityState        String?                @map("city_state")
  yearsProducing   String                 @map("years_producing") // "3-5" | "6-10" | "10+"
  genre            String
  productionStyle  String                 @map("production_style")
  imageUrl         String?                @map("image_url")
  spotifyUrl       String?                @map("spotify_url")
  appleMusicUrl    String?                @map("apple_music_url")
  websiteUrl       String?                @map("website_url")
  bio              String?
  soundCloudUrl    String?                @map("sound_cloud_url")
  twitterHandle    String?                @map("twitter_handle")
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  eventSignups     ProducerEventSignup[]
  media            ProducerMedia[]
}

model ProducerMedia {
  id          String   @id @default(cuid())
  producerId  String   @map("producer_id")
  producer    Producer @relation(fields: [producerId], references: [id], onDelete: Cascade)
  url         String
  kind        String   // image | audio | video
  displayName String?  @map("display_name")
  sizeBytes   Int?     @map("size_bytes")
  mimeType    String?  @map("mime_type")
  createdAt   DateTime @default(now())

  @@index([producerId])
}

model ProducerEventSignup {
  id              String   @id @default(cuid())
  producerId      String   @map("producer_id")
  producer        Producer @relation(fields: [producerId], references: [id], onDelete: Cascade)
  eventId         String   @map("event_id")
  event           Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  agreeRules      Boolean  @map("agree_rules")
  agreeOriginal   Boolean  @map("agree_original")
  agreeTimeLimits Boolean  @map("agree_time_limits")
  participantId   String?  @map("participant_id") // set when admin adds to bracket
  createdAt       DateTime @default(now())

  @@unique([producerId, eventId])
  @@index([eventId])
  @@index([producerId])
}

model Participant {
  id                  String              @id @default(cuid())
  eventId             String
  event               Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name                String
  imageUrl            String?
  seed                Int?                // optional bracket seed
  createdAt           DateTime            @default(now())
  matchupParticipants MatchupParticipant[]
  votes               Vote[]
}

model Round {
  id            String    @id @default(cuid())
  eventId       String
  event         Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  roundIndex    Int       // 0 = first round, etc.
  label         String    // e.g. "Quarter-finals"
  status        String    @default("upcoming") // upcoming | live | completed
  resultsVisible Boolean  @default(false)
  createdAt     DateTime  @default(now())
  matchups      Matchup[]
}

model Matchup {
  id           String              @id @default(cuid())
  eventId      String
  event        Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)
  roundId      String
  round        Round               @relation(fields: [roundId], references: [id], onDelete: Cascade)
  orderInRound Int                 // order within round for display
  status       String              @default("pending") // pending | live | completed
  voteEndsAt   DateTime?           // when voting closes; null = until admin ends
  createdAt    DateTime            @default(now())
  participants MatchupParticipant[]
  votes        Vote[]
}

model MatchupParticipant {
  id            String      @id @default(cuid())
  matchupId     String
  matchup       Matchup     @relation(fields: [matchupId], references: [id], onDelete: Cascade)
  participantId String
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  slotIndex     Int         // 0, 1, 2, ... for display order
  createdAt     DateTime    @default(now())

  @@unique([matchupId, slotIndex])
  @@index([matchupId])
  @@index([participantId])
}

model VoterIdentity {
  id            String   @id @default(cuid())
  name          String
  email         String
  phone         String
  contactConsent Boolean @default(false)
  createdAt     DateTime @default(now())
  votes         Vote[]
}

model Vote {
  id             String        @id @default(cuid())
  matchupId      String
  matchup        Matchup       @relation(fields: [matchupId], references: [id], onDelete: Cascade)
  voterIdentityId String
  voterIdentity  VoterIdentity @relation(fields: [voterIdentityId], references: [id], onDelete: Cascade)
  participantId  String
  participant    Participant   @relation(fields: [participantId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())

  @@unique([matchupId, voterIdentityId])
  @@index([matchupId])
  @@index([voterIdentityId])
}

model ShowState {
  id               String   @id @default(cuid())
  eventId          String   @unique
  event            Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  currentMatchupId String?
  updatedAt        DateTime @updatedAt
}
